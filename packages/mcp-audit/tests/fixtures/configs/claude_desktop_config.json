{
  "mcpServers": {
    "unpinned-tools": {
      "command": "npx",
      "args": ["-y", "example-tools-mcp"]
    },
    "leaky-notes": {
      "command": "npx",
      "args": ["-y", "notes-mcp@1.0.2"],
      "env": {
        "NOTES_API_KEY": "sk-FAKEFAKEFAKEFAKEFAKEFAKE1234",
        "NOTES_REGION": "us-east-1",
        "SAFE_REF": "${NOTES_TOKEN}"
      }
    },
    "pinned-clean": {
      "command": "npx",
      "args": ["-y", "@example/well-kept-mcp@2.1.0"]
    },
    "local-script": {
      "command": "node",
      "args": ["./servers/local.js"]
    }
  }
}
